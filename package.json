{
  "name": "@creativoma/liquid-glass",
  "version": "1.1.2",
  "type": "module",
  "description": "A React wrapper component with liquid frosted glass effect using TailwindCSS",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/creativoma/liquid-glass#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creativoma/liquid-glass.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build:demo": "vite build --config vite.config.ts",
    "build:lib": "tsc && vite build --config vite.config.lib.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build:lib"
  },
  "keywords": [
    "react",
    "glass",
    "frosted-glass",
    "liquid-glass",
    "glassmorphism",
    "backdrop-filter",
    "component",
    "tailwindcss",
    "wrapper",
    "ui",
    "typescript",
    "frontend"
  ],
  "author": {
    "name": "creativoma"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
